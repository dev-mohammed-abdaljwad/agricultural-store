@baseUrl = http://localhost:8000/api/v1
@adminEmail = admin@nileharvest.com
@adminToken = 
@customerEmail = ahmed@example.com
@customerToken = 
@productId = 1
@orderId = 1
@quoteId = 1

###
### AUTHENTICATION ENDPOINTS
###

### Register as Customer
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Test Customer",
  "email": "test@example.com",
  "password": "SecurePassword123",
  "password_confirmation": "SecurePassword123",
  "phone": "+201001234567",
  "customer_type": "farmer",
  "governorate": "Cairo",
  "address": "123 Test Street, Cairo"
}

###
### Login (Customer)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "ahmed@example.com",
  "password": "password"
}

@customerToken = 1|your-token-here

###
### Login (Admin)
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "admin@nileharvest.com",
  "password": "password"
}

@adminToken = 1|your-token-here

###
### Get Current User (Customer)
GET {{baseUrl}}/auth/me
Authorization: Bearer {{customerToken}}

###
### Logout
POST {{baseUrl}}/auth/logout
Authorization: Bearer {{customerToken}}

###
### PRODUCTS ENDPOINTS (PUBLIC)
###

### List All Products (Public)
GET {{baseUrl}}/products?per_page=10&page=1
Content-Type: application/json

###
### List Products by Category
GET {{baseUrl}}/products?category_id=1&per_page=10
Content-Type: application/json

###
### Search Products
GET {{baseUrl}}/products?search=tomato
Content-Type: application/json

###
### Get Single Product
GET {{baseUrl}}/products/{{productId}}
Content-Type: application/json

###
### CATEGORIES ENDPOINTS (PUBLIC)
###

### List All Categories
GET {{baseUrl}}/categories
Content-Type: application/json

###
### CUSTOMER ORDER ENDPOINTS
###

### Place a New Order
POST {{baseUrl}}/orders
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "items": [
    {
      "product_id": 1,
      "quantity": 10
    },
    {
      "product_id": 2,
      "quantity": 5
    }
  ],
  "delivery_address": "123 Farm Road, Giza",
  "delivery_governorate": "Giza",
  "payment_method": "cod"
}

###
### Get Customer's Orders
GET {{baseUrl}}/orders?per_page=15&page=1
Authorization: Bearer {{customerToken}}
Content-Type: application/json

###
### Get Single Order
GET {{baseUrl}}/orders/{{orderId}}
Authorization: Bearer {{customerToken}}
Content-Type: application/json

###
### Accept Quote
POST {{baseUrl}}/orders/{{orderId}}/quotes/{{quoteId}}/accept
Authorization: Bearer {{customerToken}}
Content-Type: application/json

###
### Reject Quote
POST {{baseUrl}}/orders/{{orderId}}/quotes/{{quoteId}}/reject
Authorization: Bearer {{customerToken}}
Content-Type: application/json

###
### MESSAGES/CHAT ENDPOINTS
###

### Get Order Messages
GET {{baseUrl}}/orders/{{orderId}}/messages
Authorization: Bearer {{customerToken}}
Content-Type: application/json

###
### Send Message in Order Conversation
POST {{baseUrl}}/orders/{{orderId}}/messages
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "body": "When will my order be delivered?"
}

###
### ADMIN PRODUCT ENDPOINTS
###

### List All Products (Admin - with supplier info)
GET {{baseUrl}}/admin/products?per_page=15&page=1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### List Admin Products by Status
GET {{baseUrl}}/admin/products?status=active
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### Create New Product
POST {{baseUrl}}/admin/products
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "category_id": 1,
  "name": "Organic Cucumbers",
  "description": "Fresh organic cucumbers from local farms",
  "unit": "kg",
  "min_order_qty": 5,
  "is_certified": true,
  "data_sheet_url": "https://example.com/cucumber-sheet.pdf",
  "usage_instructions": "Rinse and use fresh or cook",
  "safety_instructions": "Wash thoroughly before use",
  "manufacturer_info": "Local organic farm",
  "expert_tip": "Best consumed within 3-5 days",
  "expert_name": "Dr. Fatima Ali",
  "expert_title": "Agricultural Specialist",
  "expert_image_url": "https://example.com/expert-fatima.jpg",
  "supplier_name": "Green Valley Farms",
  "supplier_code": "GVF-004",
  "status": "active"
}

###
### Update Product
PUT {{baseUrl}}/admin/products/{{productId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "name": "Premium Organic Cucumbers",
  "description": "Fresh premium organic cucumbers",
  "min_order_qty": 3
}

###
### Delete Product
DELETE {{baseUrl}}/admin/products/{{productId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### Add Product Images
POST {{baseUrl}}/admin/products/{{productId}}/images
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "images": [
    {
      "url": "https://example.com/cucumbers-1.jpg",
      "is_primary": true,
      "sort_order": 1
    },
    {
      "url": "https://example.com/cucumbers-2.jpg",
      "is_primary": false,
      "sort_order": 2
    },
    {
      "url": "https://example.com/cucumbers-3.jpg",
      "is_primary": false,
      "sort_order": 3
    }
  ]
}

###
### Sync Product Specifications
PUT {{baseUrl}}/admin/products/{{productId}}/specs
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "specs": [
    {
      "key": "Origin",
      "value": "Egypt - Nile Delta",
      "sort_order": 1
    },
    {
      "key": "Shelf Life",
      "value": "5 days at room temperature",
      "sort_order": 2
    },
    {
      "key": "Organic Certification",
      "value": "IFOAM Certified",
      "sort_order": 3
    },
    {
      "key": "Packaging Type",
      "value": "Wooden crates",
      "sort_order": 4
    }
  ]
}

###
### ADMIN ORDER ENDPOINTS
###

### List All Orders (Admin)
GET {{baseUrl}}/admin/orders?per_page=20&page=1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### List Orders by Status
GET {{baseUrl}}/admin/orders?status=placed&per_page=20
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### Get Single Order (Admin)
GET {{baseUrl}}/admin/orders/{{orderId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### Send Quote to Customer
POST {{baseUrl}}/admin/orders/{{orderId}}/quotes
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "items": [
    {
      "order_item_id": 1,
      "unit_price": 45.00
    },
    {
      "order_item_id": 2,
      "unit_price": 65.00
    }
  ],
  "delivery_fee": 30.00,
  "notes": "Valid for 48 hours. Price negotiable for bulk orders.",
  "expires_in_hours": 48
}

###
### Update Order Status
PATCH {{baseUrl}}/admin/orders/{{orderId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "preparing",
  "description": "Started preparation of items"
}

###
### Update Order Status to In Transit
PATCH {{baseUrl}}/admin/orders/{{orderId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "out_for_delivery",
  "description": "Order is out for delivery with our logistics partner"
}

###
### Update Order Status to Delivered
PATCH {{baseUrl}}/admin/orders/{{orderId}}/status
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "status": "delivered",
  "description": "Order delivered successfully"
}

###
### Get Order Tracking History
GET {{baseUrl}}/admin/orders/{{orderId}}/tracking
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### ADMIN CONVERSATIONS ENDPOINTS
###

### List All Conversations (Admin)
GET {{baseUrl}}/admin/conversations?per_page=20&page=1
Authorization: Bearer {{adminToken}}
Content-Type: application/json

###
### Send Message as Admin
POST {{baseUrl}}/orders/{{orderId}}/messages
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "body": "Your order will be ready for pickup tomorrow at 10 AM"
}

###
### FULL WORKFLOW EXAMPLE
### 1. Customer registers
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
  "name": "Workflow Test",
  "email": "workflow@test.com",
  "password": "TestPass123!",
  "password_confirmation": "TestPass123!",
  "phone": "+201231234567",
  "customer_type": "farmer",
  "governorate": "Beheira",
  "address": "Farm #5, Beheira"
}

### 2. Customer logs in
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
  "email": "workflow@test.com",
  "password": "TestPass123!"
}

### 3. Customer browses products
GET {{baseUrl}}/products?category_id=1

### 4. Customer places order
POST {{baseUrl}}/orders
Authorization: Bearer YOUR_CUSTOMER_TOKEN
Content-Type: application/json

{
  "items": [
    {
      "product_id": 1,
      "quantity": 20
    }
  ],
  "delivery_address": "Farm #5, Beheira",
  "delivery_governorate": "Beheira",
  "payment_method": "cod"
}

### 5. Admin views order
GET {{baseUrl}}/admin/orders/RETURNED_ORDER_ID
Authorization: Bearer YOUR_ADMIN_TOKEN

### 6. Admin sends quote
POST {{baseUrl}}/admin/orders/RETURNED_ORDER_ID/quotes
Authorization: Bearer YOUR_ADMIN_TOKEN
Content-Type: application/json

{
  "items": [
    {
      "order_item_id": RETURNED_ORDER_ITEM_ID,
      "unit_price": 50.00
    }
  ],
  "delivery_fee": 50.00,
  "expires_in_hours": 48
}

### 7. Customer reads messages
GET {{baseUrl}}/orders/RETURNED_ORDER_ID/messages
Authorization: Bearer YOUR_CUSTOMER_TOKEN

### 8. Customer accepts quote
POST {{baseUrl}}/orders/RETURNED_ORDER_ID/quotes/RETURNED_QUOTE_ID/accept
Authorization: Bearer YOUR_CUSTOMER_TOKEN

### 9. Admin updates order status
PATCH {{baseUrl}}/admin/orders/RETURNED_ORDER_ID/status
Authorization: Bearer YOUR_ADMIN_TOKEN
Content-Type: application/json

{
  "status": "paid"
}

### 10. Admin sends message about delivery
POST {{baseUrl}}/orders/RETURNED_ORDER_ID/messages
Authorization: Bearer YOUR_ADMIN_TOKEN
Content-Type: application/json

{
  "body": "Your order will be delivered tomorrow at 9 AM"
}

### 11. Admin marks order as preparing
PATCH {{baseUrl}}/admin/orders/RETURNED_ORDER_ID/status
Authorization: Bearer YOUR_ADMIN_TOKEN
Content-Type: application/json

{
  "status": "preparing"
}

### 12. Admin marks order as out for delivery
PATCH {{baseUrl}}/admin/orders/RETURNED_ORDER_ID/status
Authorization: Bearer YOUR_ADMIN_TOKEN
Content-Type: application/json

{
  "status": "out_for_delivery"
}

### 13. Admin marks order as delivered
PATCH {{baseUrl}}/admin/orders/RETURNED_ORDER_ID/status
Authorization: Bearer YOUR_ADMIN_TOKEN
Content-Type: application/json

{
  "status": "delivered"
}
